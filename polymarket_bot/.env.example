# ═══════════════════════════════════════════════════
# POLYMARKET BTC BOT — .env TEMPLATE
# Kopiraj v .env in vnesi prave vrednosti
# ═══════════════════════════════════════════════════

# Binance API (samo Read dovoljenje!)
BINANCE_API_KEY=tvoj_binance_api_key_tukaj

# MetaMask Polygon wallet
POLY_PRIVATE_KEY=0x_tvoj_metamask_private_key
POLY_ADDRESS=0x_tvoj_polygon_naslov

# Polymarket CLOB API (generiraj z client.create_or_derive_api_creds())
POLY_API_KEY=iz_polymarket_create_or_derive
POLY_API_SECRET=iz_polymarket_create_or_derive
POLY_API_PASSPHRASE=iz_polymarket_create_or_derive
